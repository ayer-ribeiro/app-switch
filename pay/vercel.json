{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "<https://pay-nine-tan.vercel.app/payment-manifest.json>; rel=\"payment-method-manifest\""
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Link",
          "value": "<https://pay-nine-tan.vercel.app/payment-manifest.json>; rel=\"payment-method-manifest\""
        }
      ]
    },
    {
      "source": "/payment-manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/x-payment-manifest" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
